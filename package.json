{
  "name": "odata-gateway-bq",
  "version": "1.0.0",
  "type": "module",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "obq-gateway/dist/obq-gateway/src/app.js",
  "directories": {
    "doc": "docs",
    "test": "obq-gateway/test"
  },
  "scripts": {
    "test": "npm run validate:boundary && npm run build:backend && tsc -p obq-gateway/test/tsconfig.json && cross-env TENANTS_CONFIG_PATH=obq-gateway/config/tenants.yaml OIDC_ISSUER=http://localhost/ OIDC_AUDIENCE=test-audience BQ_BILLING_PROJECT_ID=test-project GCP_WORKLOAD_POOL_ID=test-project GCP_WORKLOAD_PROVIDER_ID=test-provider FASTIFY_AUTOLOAD_TYPESCRIPT=1 node --test --test-concurrency 1 --import tsx obq-gateway/test/**/*.test.ts",
    "validate:boundary": "./playwright/scripts/validate-git-boundary.sh",
    "test:agent": "node playwright/scripts/test-agent-runner.cjs",
    "test:e2e:hybrid": "node playwright/scripts/e2e-hybrid-router.cjs",
    "start": "npm run build:backend && fastify start --options -a 0.0.0.0 -l info -T 30000 obq-gateway/dist/obq-gateway/src/app.js --port ${PORT:-80}",
    "build:backend": "cd obq-gateway && tsc",
    "watch:backend": "cd obq-gateway && tsc -w",
    "dev": "concurrently -k -p \"[{name}]\" -n \"Gateway,Hub\" -c \"yellow.bold,cyan.bold\" \"npm:dev:backend\" \"npm:dev:frontend:delayed\"",
    "dev:clean": "node scripts/dev-clean.js",
    "dev:backend": "node scripts/dev-backend.js",
    "dev:frontend": "cd obq-hub && npm run dev",
    "dev:frontend:delayed": "node scripts/dev-frontend-delayed.js"
  },
  "keywords": [],
  "author": "Amine MOKHTARI",
  "license": "Apache-2.0",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/oauth2": "^8.2.0",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/sensible": "^6.0.0",
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/bigquery-storage": "^5.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "fastify-cli": "^8.0.0",
    "fastify-plugin": "^5.0.0",
    "google-auth-library": "^10.6.2",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.1",
    "lru-cache": "^11.3.5",
    "protobufjs": "^7.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.3",
    "c8": "^11.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "fastify-tsconfig": "^3.0.0",
    "kill-port": "^2.0.1",
    "msw": "^2.14.5",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.10"
  }
}
