# ==============================================================================
# OData Gateway for BigQuery - Environment Template
# ==============================================================================
# Copy this file to .env and fill in your values.

# 1. Google Cloud Configuration
# ------------------------------------------------------------------------------
# All BigQuery jobs will be submitted to this project (Billing Project).
BQ_BILLING_PROJECT_ID="your-gcp-project-id"

# 2. OIDC Authentication (Azure AD / Entra ID)
# ------------------------------------------------------------------------------
# The OIDC discovery URL. Replace 'your-tenant-id' with your Tenant ID.
# Found in App Registrations -> Overview -> "Directory (tenant) ID"
OIDC_ISSUER="https://login.microsoftonline.com/your-tenant-id/v2.0"

# The audience for your application.
# Found in App Registrations -> Expose an API -> "Application ID URI" (or Application (client) ID in Overview)
OIDC_AUDIENCE="your-client-id"

# The Client ID registered in your Identity Provider.
# Found in App Registrations -> Overview -> "Application (client) ID"
# OIDC_CLIENT_ID="your-client-id"

# The Client Secret for your application.
# Found in App Registrations -> Certificates & secrets -> "Client secrets" -> "Value" (NOT Secret ID)
# OIDC_CLIENT_SECRET="your-client-secret"

# A random string used by Auth.js/NextAuth to encrypt tokens.
# Generate a secure string with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# HUB_AUTH_SECRET="your-random-auth-secret"

# Set to true if running behind a reverse proxy (e.g., in production)
# Trust host flag for NextAuth when deployed behind a proxy.
# This tells NextAuth to trust the X-Forwarded-* headers to determine the real public URL, preventing CSRF issues.
# HUB_AUTH_TRUST_HOST=true

# 3. Development & Testing Flags
# ------------------------------------------------------------------------------
# If true, disables OIDC authentication and allows unauthenticated access. Useful for quick local testing.
# WARNING: NEVER set this to true in a production environment.
ANONYMOUS_MODE=true

# When ANONYMOUS_MODE is true, this name will be used in audit logs and as the mocked user's name.
DEFAULT_ANONYMOUS_USER_NAME="ANONYMOUS"

# If true, enables MSW (Mock Service Worker) in the frontend. 
# This intercepts API requests and returns mock data, allowing UI development without a real backend.
NEXT_PUBLIC_API_MOCKING=false

# 4. Gateway Options
# ------------------------------------------------------------------------------
# Path to the YAML configuration file that defines tenant settings (BigQuery datasets, access rules, routing).
# Example: "dev-tenants.yaml" for local development.
# TENANTS_CONFIG_PATH="dev-tenants.yaml"

# If true, enables response compression (Gzip/Brotli).
# ENABLE_COMPRESSION=false

# If true, enables the Visual Join and Aggregation Query Builder feature in the Frontend Marketplace UI.
# This allows users to visually construct complex OData queries without writing raw OData syntax.
ENABLE_QUERY_BUILDER=true

# 5. URL and Port Configurations
# ------------------------------------------------------------------------------
# IMPORTANT: The server ports are now extracted directly from these URLs.
# You MUST explicitly include the port in the URL (e.g., :3000, :80) if it differs from the default 80/443.

# The URL for the OData Gateway backend (obq-gateway).
GATEWAY_URL=http://localhost:80

# The public-facing URL of the OData Gateway.
# This is exposed to the browser and used by frontend components to make direct API calls to the Gateway.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:80

# The URL for the Marketplace Frontend Hub (obq-hub).
HUB_URL=http://localhost:3000

# 5. Audit Logging Options
# ------------------------------------------------------------------------------
# The BigQuery dataset and table name where persistent logs are stored.
# BQ_AUDIT_DATASET="obq_audit_logs"
# BQ_AUDIT_TABLE="api_audit"
