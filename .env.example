# ==============================================================================
# OData Gateway for BigQuery - Environment Template
# ==============================================================================
# Copy this file to .env and fill in your values.

# 1. Google Cloud Configuration
# ------------------------------------------------------------------------------
# All BigQuery jobs will be submitted to this project (Billing Project).
BQ_BILLING_PROJECT_ID="your-gcp-project-id"

# 2. OIDC Authentication (Azure AD / Entra ID)
# ------------------------------------------------------------------------------
# The OIDC discovery URL. Replace 'your-tenant-id' with your Tenant ID.
# Found in App Registrations -> Overview -> "Directory (tenant) ID"
OIDC_ISSUER="https://login.microsoftonline.com/your-tenant-id/v2.0"

# The audience for your application.
# Found in App Registrations -> Expose an API -> "Application ID URI" (or Application (client) ID in Overview)
OIDC_AUDIENCE="your-client-id"

# The Client ID registered in your Identity Provider.
# Found in App Registrations -> Overview -> "Application (client) ID"
# OIDC_CLIENT_ID="your-client-id"

# The Client Secret for your application.
# Found in App Registrations -> Certificates & secrets -> "Client secrets" -> "Value" (NOT Secret ID)
# OIDC_CLIENT_SECRET="your-client-secret"

# A random string used by Auth.js/NextAuth to encrypt tokens.
# Generate a secure string with `openssl rand -base64 32`
# AUTH_SECRET="your-random-auth-secret"

# Trust host flag for NextAuth when deployed behind a proxy.
# AUTH_TRUST_HOST=true

# 3. Development & Testing Flags
# ------------------------------------------------------------------------------
# If true, authentication is disabled. Set to true for quick local testing.
ANONYMOUS_MODE=true

# If true, enables MSW mocking in the browser (Frontend).
NEXT_PUBLIC_API_MOCKING=false

# 4. Gateway Options
# ------------------------------------------------------------------------------
# Path to your tenant configuration file.
# TENANTS_CONFIG_PATH="dev-tenants.yaml"

# If true, enables response compression (Gzip/Brotli).
# ENABLE_COMPRESSION=false

# If true, enables the Visual Join and Aggregation builder in the Marketplace UI.
ENABLE_QUERY_BUILDER=true

# 5. Port Configurations (Explicit and Distinguishable)
# ------------------------------------------------------------------------------

# The URL for the Marketplace Frontend Hub (obq-hub). Defaults to http://localhost:3000.
HUB_URL=http://localhost:3000

# 5. Audit Logging Options
# ------------------------------------------------------------------------------
# The BigQuery dataset and table name where persistent logs are stored.
# BQ_AUDIT_DATASET="obq_audit_logs"
# BQ_AUDIT_TABLE="api_audit"
